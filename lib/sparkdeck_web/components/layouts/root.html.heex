<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="Sparkdeck">
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
    <script>
      (() => {
        const syncToggleState = (theme) => {
          document.querySelectorAll("[data-phx-theme]").forEach((button) => {
            button.classList.toggle("ui-theme-toggle__button--active", button.dataset.phxTheme === theme);
          });
        };

        const setTheme = (theme) => {
          localStorage.setItem("phx:theme", theme);
          document.documentElement.setAttribute("data-theme", theme);
          syncToggleState(theme);
        };
        if (!document.documentElement.hasAttribute("data-theme")) {
          setTheme(localStorage.getItem("phx:theme") || "dark");
        } else {
          syncToggleState(document.documentElement.getAttribute("data-theme"));
        }
        window.addEventListener("storage", (e) => e.key === "phx:theme" && setTheme(e.newValue || "dark"));

        window.addEventListener("phx:set-theme", (e) => setTheme(e.target.dataset.phxTheme));
      })();
    </script>
  </head>
  <body>
    {@inner_content}
  </body>
</html>
